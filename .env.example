# Copy to .env.local for Vite (never commit .env.local — it is gitignored).
# Get values from Supabase Dashboard → Project Settings → API (anon key, URL).

VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# Use the anon / publishable key only — never the service_role key in frontend env.
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_anon_key

# Optional: self-hosted Express API (production: set in Vercel env)
# VITE_BACKEND_URL=https://your-api.example.com

# --- Backend / Supabase Edge secrets (set in Supabase → Edge Functions → Secrets, not in this file) ---
# FINNHUB_API_KEY or FINNHUB_API_KEYS=key1,key2
# FRED_API_KEY=...          # https://fred.stlouisfed.org/docs/api/api_key.html — treasury + VIX (recommended)
# ALPHA_VANTAGE_API_KEY or ALPHA_VANTAGE_API_KEYS
# TWELVE_DATA_API_KEY or TWELVE_DATA_API_KEYS
